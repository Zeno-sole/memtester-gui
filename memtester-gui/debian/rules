#!/usr/bin/make -f

export DH_VERBOSE = 1
export QT_SELECT = qt6

DEB_HOST_GNU_TYPE ?= $(shell dpkg-architecture -qDEB_HOST_GNU_TYPE)
DEB_BUILD_GNU_TYPE ?= $(shell dpkg-architecture -qDEB_BUILD_GNU_TYPE)

ifneq ($(DEB_BUILD_GNU_TYPE),$(DEB_HOST_GNU_TYPE))
    CMAKE_TOOLCHAIN_ARG = -DCMAKE_TOOLCHAIN_FILE=/usr/share/cmake/$(DEB_HOST_GNU_TYPE)-linux-gnu.cmake
endif

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		$(CMAKE_TOOLCHAIN_ARG)

override_dh_auto_install:
	dh_auto_install
	install -Dm755 build/memtester-gui debian/memtester-gui/usr/bin/memtester-gui
	install -Dm644 debian/memtester-gui.desktop debian/memtester-gui/usr/share/applications/memtester-gui.desktop
	install -Dm644 debian/icons/memtester-gui.svg debian/memtester-gui/usr/share/icons/hicolor/scalable/apps/memtester-gui.svg

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info
